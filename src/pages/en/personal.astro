---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

const lang: Lang = 'en';
const t = useTranslations(lang);

const PROFILE_IMAGE = "https://placehold.co/480x600/d4d4c8/333?text=Your+Photo";
const SPOTIFY_EMBED = "https://open.spotify.com/embed/playlist/37i9dQZF1DXcBWIGoYBM5M?utm_source=generator&theme=0";
const GALLERY_PHOTOS = [
  { src: "https://placehold.co/600x800/d4d0cb/333?text=Photo+1",  alt: "Photo 1", span: "row-span-2" },
  { src: "https://placehold.co/600x400/ccc9c4/333?text=Photo+2",  alt: "Photo 2", span: "" },
  { src: "https://placehold.co/600x400/e0ddd8/333?text=Photo+3",  alt: "Photo 3", span: "" },
  { src: "https://placehold.co/600x800/c8c4be/333?text=Photo+4",  alt: "Photo 4", span: "row-span-2" },
  { src: "https://placehold.co/600x400/d4d0cb/333?text=Photo+5",  alt: "Photo 5", span: "" },
  { src: "https://placehold.co/600x400/ccc8c2/333?text=Photo+6",  alt: "Photo 6", span: "" },
];

const nowItems     = t('personal.now.items')     as { icon: string; label: string; text: string }[];
const hobbiesItems = t('personal.hobbies.items') as { emoji: string; title: string; desc: string }[];
---

<Layout title={t('personal.title') as string} lang={lang}>

  <!-- ══ HERO ═══════════════════════════════════════ -->
  <section class="pt-24 md:pt-28 pb-20 px-5 bg-bg-light dark:bg-bg-dark">
    <div class="max-w-6xl mx-auto">
      <p class="text-[11px] tracking-[0.22em] opacity-40 mb-8 personal-fade">{t('personal.hero.tag')}</p>
      <div class="grid grid-cols-1 md:grid-cols-[1fr_380px] gap-12 md:gap-20 items-end">
        <div>
          <h1 class="text-[clamp(3.5rem,10vw,9rem)] font-black leading-[0.88] tracking-tight mb-8 personal-heading">
            {t('personal.hero.line1')}<br/>
            <span>{t('personal.hero.line2')}</span>
          </h1>
          <p class="text-[15px] leading-relaxed opacity-60 max-w-sm personal-fade">{t('personal.hero.desc')}</p>
          <div class="mt-10 flex items-center gap-4 personal-fade">
            <span class="block w-12 h-[2px] bg-accent"></span>
            <span class="text-[11px] tracking-[0.2em] opacity-40 uppercase">Carlos Sanchez — 2026</span>
          </div>
        </div>
        <div class="relative personal-img">
          <div style="clip-path: polygon(0 0, 100% 0, 100% 90%, 90% 100%, 0 100%);" class="overflow-hidden">
            <img src={PROFILE_IMAGE} alt="Carlos Sanchez" class="w-full aspect-[4/5] object-cover object-top" />
          </div>
          <span class="absolute -bottom-4 -left-4 bg-accent text-white text-[10px] font-black tracking-[0.2em] px-3 py-2 uppercase">
            //DEV & HUMAN
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ TICKER ════════════════════════════════════ -->
  <div class="bg-[#111] dark:bg-[#f0f0eb] py-[14px] overflow-hidden">
    <div class="ticker-personal flex gap-14 whitespace-nowrap w-max">
      {["Curious","Creative","Evolving","Passionate","Honest","Direct","Human",
        "Curious","Creative","Evolving","Passionate","Honest","Direct","Human",
        "Curious","Creative","Evolving","Passionate","Honest","Direct","Human"].map(w => (
        <span class="text-[#f0f0eb] dark:text-[#111] text-[12px] font-semibold tracking-[0.2em] uppercase flex items-center gap-3">
          <span class="text-accent">◆</span>{w}
        </span>
      ))}
    </div>
  </div>

  <!-- ══ NOW ════════════════════════════════════════ -->
  <section class="px-5 py-24 bg-bg-light dark:bg-bg-dark" id="now">
    <div class="max-w-6xl mx-auto">
      <div class="mb-14 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div>
          <p class="text-[11px] tracking-[0.22em] opacity-40 mb-3 uppercase now-tag">{t('personal.now.tag')}</p>
          <h2 class="text-[clamp(2.5rem,6vw,5rem)] font-black leading-[0.9] tracking-tight whitespace-pre-line now-heading">
            {t('personal.now.heading')}
          </h2>
        </div>
        <span class="text-accent text-[3rem] font-black leading-none self-end opacity-30 select-none">✤</span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-current/10">
        {nowItems.map((item, i) => (
          <div class="now-item bg-bg-light dark:bg-bg-dark p-8 flex flex-col gap-5 group relative overflow-hidden">
            <span class="absolute top-4 right-5 text-[5rem] font-black leading-none opacity-[0.04] select-none pointer-events-none">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="flex items-center justify-between">
              <span class="text-3xl">{item.icon}</span>
              <span class="text-[10px] tracking-[0.2em] border border-current/15 rounded-full px-3 py-1 uppercase opacity-50">
                {item.label}
              </span>
            </div>
            <p class="text-[14px] leading-relaxed opacity-65 flex-1">{item.text}</p>
            <div class="h-[2px] w-0 bg-accent group-hover:w-full transition-all duration-500 mt-auto"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ HOBBIES ════════════════════════════════════ -->
  <section class="px-5 py-24 bg-[#f5f5f2] dark:bg-[#181818]" id="hobbies">
    <div class="max-w-6xl mx-auto">
      <div class="mb-14">
        <p class="text-[11px] tracking-[0.22em] opacity-40 mb-3 uppercase hobby-tag">{t('personal.hobbies.tag')}</p>
        <h2 class="text-[clamp(2.5rem,6vw,5rem)] font-black leading-[0.9] tracking-tight whitespace-pre-line hobby-heading">
          {t('personal.hobbies.heading')}
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-current/10">
        {hobbiesItems.map(hobby => (
          <div class="bg-bg-light dark:bg-bg-dark p-7 flex flex-col gap-4 hobby-card group hover:bg-accent/5 transition-colors duration-300">
            <span class="text-3xl">{hobby.emoji}</span>
            <div>
              <h3 class="text-[15px] font-black tracking-tight mb-2">{hobby.title}</h3>
              <p class="text-[13px] leading-relaxed opacity-55">{hobby.desc}</p>
            </div>
            <div class="mt-auto pt-4 border-t border-current/5">
              <span class="block w-0 h-[2px] bg-accent group-hover:w-full transition-all duration-500"></span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ SPOTIFY ════════════════════════════════════ -->
  <section class="px-5 py-24 bg-bg-light dark:bg-bg-dark overflow-hidden" id="spotify">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12">
        <p class="text-[11px] tracking-[0.22em] opacity-40 mb-3 uppercase spotify-tag">{t('personal.spotify.tag')}</p>
        <h2 class="text-[clamp(2.5rem,6vw,5rem)] font-black leading-[0.9] tracking-tight whitespace-pre-line spotify-heading">
          {t('personal.spotify.heading')}
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-10 items-start">
        <div class="spotify-embed overflow-hidden rounded-3xl" style="clip-path: polygon(0 0, 100% 0, 100% 94%, 94% 100%, 0 100%);">
          <iframe src={SPOTIFY_EMBED} width="100%" height="380" frameborder="0"
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy" class="block"></iframe>
        </div>
        <div class="md:w-52 flex flex-col gap-4 spotify-text">
          <p class="text-[13px] leading-relaxed opacity-55">{t('personal.spotify.note')}</p>
          <div class="flex flex-col gap-2">
            <span class="text-[11px] tracking-[0.2em] opacity-30 uppercase">Genres</span>
            {["Lo-fi","Jazz Fusion","Post-rock","Electronic"].map(g => (
              <span class="text-[13px] opacity-60 border-b border-current/10 pb-1">{g}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ GALLERY ════════════════════════════════════ -->
  <section class="px-5 py-24 bg-[#f5f5f2] dark:bg-[#181818]" id="gallery">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12">
        <p class="text-[11px] tracking-[0.22em] opacity-40 mb-3 uppercase gallery-tag">{t('personal.gallery.tag')}</p>
        <h2 class="text-[clamp(2.5rem,6vw,5rem)] font-black leading-[0.9] tracking-tight whitespace-pre-line gallery-heading">
          {t('personal.gallery.heading')}
        </h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 auto-rows-[130px] md:auto-rows-[160px] gap-2">
        {GALLERY_PHOTOS.map(photo => (
          <div class={`overflow-hidden gallery-item ${photo.span}`}>
            <img src={photo.src} alt={photo.alt} loading="lazy"
              class="w-full h-full object-cover transition-all duration-700 scale-100 hover:scale-105 grayscale-[20%] hover:grayscale-0" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer lang={lang} />

</Layout>

<style>
  .ticker-personal { animation: ticker-p 28s linear infinite; }
  @keyframes ticker-p { 0%{transform:translateX(0)} 100%{transform:translateX(-33.333%)} }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.personal-heading', { y:80, opacity:0, clipPath:'inset(0 0 100% 0)', duration:1.1, ease:'power4.out', delay:0.3 });
  gsap.from('.personal-fade',    { y:20, opacity:0, duration:0.9, stagger:0.15, ease:'power3.out', delay:0.7 });
  gsap.from('.personal-img',     { x:60, opacity:0, duration:1.2, ease:'power3.out', delay:0.5 });

  const st = (trigger: string, start = 'top 80%') => ({ trigger, start, toggleActions:'play none none none' });
  gsap.from('.now-tag',      { opacity:0, x:-20, duration:0.8, ease:'power3.out', scrollTrigger: st('#now','top 82%') });
  gsap.from('.now-heading',  { y:50, opacity:0, duration:1, ease:'power3.out', scrollTrigger: st('#now') });
  gsap.from('.now-item',     { x:-40, opacity:0, duration:0.7, stagger:0.1, ease:'power3.out', scrollTrigger: st('#now','top 70%') });
  gsap.from('.hobby-tag',    { opacity:0, x:-20, duration:0.8, ease:'power3.out', scrollTrigger: st('#hobbies','top 82%') });
  gsap.from('.hobby-heading',{ y:50, opacity:0, duration:1, ease:'power3.out', scrollTrigger: st('#hobbies') });
  gsap.from('.hobby-card',   { y:40, opacity:0, duration:0.6, stagger:0.08, ease:'power3.out', scrollTrigger: st('#hobbies','top 75%') });
  gsap.from('.spotify-tag',  { opacity:0, x:-20, duration:0.8, ease:'power3.out', scrollTrigger: st('#spotify','top 82%') });
  gsap.from('.spotify-heading',{ y:50, opacity:0, duration:1, ease:'power3.out', scrollTrigger: st('#spotify') });
  gsap.from('.spotify-embed',{ x:-50, opacity:0, duration:1.1, ease:'power3.out', scrollTrigger: st('#spotify','top 75%') });
  gsap.from('.spotify-text', { x:30, opacity:0, duration:1, ease:'power3.out', delay:0.2, scrollTrigger: st('#spotify','top 75%') });
  gsap.from('.gallery-tag',  { opacity:0, x:-20, duration:0.8, ease:'power3.out', scrollTrigger: st('#gallery','top 82%') });
  gsap.from('.gallery-heading',{ y:50, opacity:0, duration:1, ease:'power3.out', scrollTrigger: st('#gallery') });
  gsap.from('.gallery-item', { scale:0.92, opacity:0, duration:0.7, stagger:0.07, ease:'power3.out', scrollTrigger: st('#gallery','top 78%') });
</script>
