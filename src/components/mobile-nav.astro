---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';

interface Props { lang?: Lang }
const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const links  = t('mobile.links')  as { label: string; href: string }[];
const cvPath = import.meta.env.PUBLIC_CV_PATH ?? '/cv-carlos-sanchez.pdf';
---

<div
  id="mobile-nav"
  class="fixed inset-0 z-40 bg-bg-light dark:bg-bg-dark -translate-x-full transition-transform duration-300 flex flex-col justify-between"
>
  <!-- Cabecera -->
  <div>
    <div class="h-16 flex items-center justify-between px-5 border-b border-black/5 dark:border-white/5">
      <span class="text-[13px] font-black tracking-[0.25em] uppercase">{t('mobile.menu')}</span>
      <button id="close-menu-btn" class="p-1 hover:opacity-50 transition-opacity" aria-label={t('mobile.close')}>
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <line x1="1" y1="1" x2="17" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="17" y1="1" x2="1" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Links de navegación -->
    <nav class="flex flex-col px-5 pt-8 gap-1">
      {links.map(link => (
        <a
          href={link.href}
          class="mobile-link text-[2.2rem] font-black leading-tight hover:text-accent transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Botón descargar CV -->
    <div class="px-5 mt-8">
      <a
        href={cvPath}
        download
        class="inline-flex items-center gap-2 border border-current/20 rounded-full px-5 py-3 text-[13px] font-semibold hover:border-accent hover:text-accent transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <line x1="6" y1="1" x2="6" y2="9"/><polyline points="3 6 6 9 9 6"/><line x1="1" y1="11" x2="11" y2="11"/>
        </svg>
        {t('nav.cv')}
      </a>
    </div>
  </div>

  <!-- Footer del menú -->
  <div class="px-5 pb-8 flex items-center justify-between">
    <p class="text-[11px] opacity-40">{t('mobile.copyright')} © {new Date().getFullYear()}</p>
    <!-- Switcher idioma -->
    <a
      href={lang === 'es' ? '/en' : '/'}
      class="text-[12px] font-black tracking-widest border border-current/20 rounded-full px-3 py-1 hover:border-accent hover:text-accent transition-colors"
    >
      {t('nav.lang')}
    </a>
  </div>
</div>

<script is:inline>
  document.getElementById('close-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-nav')?.classList.add('-translate-x-full');
  });
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      document.getElementById('mobile-nav')?.classList.add('-translate-x-full');
    });
  });
</script>
