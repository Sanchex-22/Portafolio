---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';
import MobileNav from '../components/mobile-nav.astro';

interface Props {
  title: string;
  lang?: Lang;
}

const { title, lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const whatsapp = import.meta.env.PUBLIC_WHATSAPP ?? '';
const cvPath   = import.meta.env.PUBLIC_CV_PATH  ?? '/cv-carlos-sanchez.pdf';
const github   = import.meta.env.PUBLIC_GITHUB   ?? 'https://github.com/sanchex-22';
const linkedin = import.meta.env.PUBLIC_LINKEDIN  ?? '#';

// URL del idioma alternativo
const altLangUrl = lang === 'es' ? '/en' : '/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={lang === 'es' ? 'Carlos Sanchez — Portafolio de Desarrollador' : 'Carlos Sanchez — Developer Portfolio'} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="es" href="/" />
    <link rel="alternate" hreflang="en" href="/en" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-bg-light dark:bg-bg-dark text-[#111] dark:text-[#f0f0eb] transition-colors duration-300 font-sans">

    <!-- ══ NAVBAR ══════════════════════════════════ -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-bg-light/90 dark:bg-bg-dark/90 backdrop-blur-sm">
      <div class="max-w-7xl mx-auto px-5 h-16 flex items-center justify-between">

        <!-- Hamburger (mobile) -->
        <button id="menu-btn" class="md:hidden p-1" aria-label={t('nav.menu')}>
          <svg width="22" height="14" viewBox="0 0 22 14" fill="none">
            <line x1="0" y1="1" x2="22" y2="1" stroke="currentColor" stroke-width="2"/>
            <line x1="0" y1="7" x2="22" y2="7" stroke="currentColor" stroke-width="2"/>
            <line x1="0" y1="13" x2="22" y2="13" stroke="currentColor" stroke-width="2"/>
          </svg>
        </button>

        <!-- Desktop nav — izquierda -->
        <div class="hidden md:flex items-center gap-7 text-[13px] tracking-wide">
          <a href={lang === 'es' ? '/' : '/en'} class="hover:opacity-50 transition-opacity">{t('nav.home')}</a>
          <a href="#about"    class="hover:opacity-50 transition-opacity">{t('nav.about')}</a>
          <a href="#projects" class="hover:opacity-50 transition-opacity">{t('nav.projects')}</a>
        </div>

        <!-- Centro — brand -->
        <a href={lang === 'es' ? '/' : '/en'} class="absolute left-1/2 -translate-x-1/2 text-[13px] font-black tracking-[0.25em] uppercase whitespace-nowrap">
          Carlos Sanchez
        </a>

        <!-- Derecha — acciones -->
        <div class="flex items-center gap-2 md:gap-3">

          <!-- Botón descargar CV -->
          <a
            href={cvPath}
            download
            class="hidden md:flex items-center gap-2 border border-current/20 rounded-full px-3 py-[5px] text-[11px] font-semibold tracking-wide hover:border-accent hover:text-accent transition-colors"
            aria-label={t('nav.cv')}
          >
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <line x1="6" y1="1" x2="6" y2="9"/>
              <polyline points="3 6 6 9 9 6"/>
              <line x1="1" y1="11" x2="11" y2="11"/>
            </svg>
            CV
          </a>

          <!-- GitHub -->
          <a href={github} target="_blank" rel="noopener" class="hidden md:flex hover:opacity-50 transition-opacity" aria-label="GitHub">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </a>

          <!-- LinkedIn -->
          <a href={linkedin} target="_blank" rel="noopener" class="hidden md:flex hover:opacity-50 transition-opacity" aria-label="LinkedIn">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>

          <!-- Switcher idioma -->
          <a
            href={altLangUrl}
            class="text-[12px] font-black tracking-widest border border-current/20 rounded-full w-9 h-9 flex items-center justify-center hover:border-accent hover:text-accent transition-colors"
            aria-label={t('nav.langFull')}
          >
            {t('nav.lang')}
          </a>

          <!-- Dark mode toggle -->
          <button id="theme-toggle" class="p-1 hover:opacity-50 transition-opacity" aria-label={t('nav.theme')}>
            <svg id="icon-sun" class="hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <svg id="icon-moon" class="block dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <MobileNav lang={lang} />
    <slot />

    <!-- ── WhatsApp flotante ── -->
    {whatsapp && (
      <a
        href={`https://wa.me/${whatsapp}?text=${encodeURIComponent(lang === 'es' ? 'Hola Carlos, vi tu portafolio y me gustaría contactarte.' : 'Hi Carlos, I saw your portfolio and I would like to get in touch.')}`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="WhatsApp"
        class="fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full bg-[#25D366] text-white shadow-lg flex items-center justify-center hover:scale-110 hover:shadow-xl transition-all duration-200"
      >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </a>
    )}

    <script is:inline>
      // Inicializar tema
      (function () {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();

      // Toggle tema
      document.getElementById('theme-toggle').addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });

      // Mobile menu
      document.getElementById('menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-nav')?.classList.toggle('-translate-x-full');
      });

      // Smooth scroll con offset del navbar fijo
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          const href = this.getAttribute('href');
          if (!href || href === '#') return;
          const target = document.querySelector(href);
          if (!target) return;
          e.preventDefault();
          const top = target.getBoundingClientRect().top + window.scrollY - 72;
          window.scrollTo({ top, behavior: 'smooth' });
          document.getElementById('mobile-nav')?.classList.add('-translate-x-full');
        });
      });
    </script>
  </body>
</html>
